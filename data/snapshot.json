      "issuetype": "Task",
      "status": {
        "name": "In Progress",
        "category": "indeterminate"
      },
      "priority": "Low",
      "assignee": {
        "name": "Kim HoGeun （ 김호근 ）",
        "displayName": "Kim HoGeun （ 김호근 ）",
        "avatar": "https://jira.workers-hub.com/secure/useravatar?avatarId=10122"
