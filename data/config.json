{
  "jiraBaseUrl": "https://jira.workers-hub.com",
  "projects": [
    "UNIFY",
    "W3P"
  ],
  "currentUser": "hogeun.kim",
  "jql": "project in (W3P, UNIFY) AND status in (Open, \"In Progress\", Reopened) AND resolution = Unresolved AND (assignee in (currentUser()) OR reporter in (currentUser())) ORDER BY priority DESC, updated DESC",
  "fetchLimit": 50,
  "labelOrder": [],
  "weekStart": "monday",
  "startDateField": "customfield_10300",
  "epicLinkField": "customfield_10108",
  "ganttDependencyLinkTypes": [
    "Finish-to-Start link (WBSGantt)",
    "Blocks"
  ],
  "descriptionLinkRules": [
    {
      "match": [
        "figma.com"
      ],
      "category": "design",
      "label": "Design"
    },
    {
      "match": [
        "github.com",
        "gitlab"
      ],
      "category": "code",
      "label": "Code"
    },
    {
      "match": [
        "confluence",
        "/wiki/",
        "wiki.workers-hub.com"
      ],
      "category": "docs",
      "label": "Wiki"
    },
    {
      "match": [
        "docs.google",
        "sheets.google",
        "drive.google"
      ],
      "category": "docs",
      "label": "Drive"
    },
    {
      "match": [
        "slack.com"
      ],
      "category": "chat",
      "label": "Slack"
    },
    {
      "match": [
        "jira.workers-hub.com/browse"
      ],
      "category": "jira",
      "label": "Jira"
    },
    {
      "match": [
        "*"
      ],
      "category": "link",
      "label": "Link"
    }
  ]
}
